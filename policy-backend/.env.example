# PolicyPlain backend — copy to .env and adjust

# 方式一：写完整异步连接串（推荐与 ORM、迁移工具一致）
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/policy_plain

# 方式二：留空 DATABASE_URL，改用下面分项（密码中的特殊字符会自动 URL 编码）
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
# 与 DB_USER 等价（二选一即可）
# DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=policy_plain

# 注册验证码邮件（QQ：smtp.qq.com:465 + 邮箱授权码；未配置则无法发送验证码）
MAIL_SMTP_HOST=smtp.qq.com
MAIL_SMTP_PORT=465
MAIL_SMTP_TIMEOUT=30
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
REGISTER_CODE_TTL_SECONDS=600
REGISTER_CODE_RESEND_SECONDS=60

# 建库并填好连接后，在 policy-backend 目录执行：python -m alembic upgrade head（或 scripts/init_db.*）

JWT_SECRET_KEY=replace-with-long-random-string

CORS_ORIGINS=*

POLICY_TEXT_MAX_CHARS=12000
LLM_TIMEOUT_SECONDS=120

# Optional: OpenAI-compatible API (leave empty to use built-in mock result)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
