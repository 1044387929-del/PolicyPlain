# PolicyPlain backend — copy to .env and adjust

# 方式一：写完整异步连接串（推荐与 ORM、迁移工具一致）
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/policy_plain

# 方式二：留空 DATABASE_URL，改用下面分项（密码中的特殊字符会自动 URL 编码）
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
# 与 DB_USER 等价（二选一即可）
# DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=policy_plain

# Redis（与 hr-backend 一致；注册验证码缓存在 PolicyCache）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# 邮件（命名对齐 hr-backend：MAIL_SERVER / MAIL_PORT / MAIL_STARTTLS / MAIL_SSL_TLS / MAIL_FROM_NAME）
MAIL_SERVER=smtp.qq.com
MAIL_PORT=465
MAIL_STARTTLS=false
MAIL_SSL_TLS=true
MAIL_FROM_NAME=PolicyPlain
MAIL_SMTP_TIMEOUT=30
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
REGISTER_CODE_TTL_SECONDS=600
REGISTER_CODE_RESEND_SECONDS=60

# 建库并填好连接后，在 policy-backend 目录执行：python -m alembic upgrade head（或 scripts/init_db.*）

JWT_SECRET_KEY=replace-with-long-random-string

CORS_ORIGINS=*

POLICY_TEXT_MAX_CHARS=12000
LLM_TIMEOUT_SECONDS=120

# 政策解读 LLM（与 hr-backend 一致：阿里云百炼 OpenAI 兼容模式 + 通义千问）
# 留空则 /policy/explain 使用内置 mock；密钥二选一：DASHSCOPE_API_KEY（与 hr 同名）或 OPENAI_API_KEY
DASHSCOPE_API_KEY=
# OPENAI_API_KEY=
# 官方 OpenAI 时改为：https://api.openai.com/v1 并设置对应模型名
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3-max
